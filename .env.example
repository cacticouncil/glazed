MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=tilearchive
DB_USER=ceramadmin
DB_PASSWORD=glazed-dev-password
DB_HOST=tile-db
DB_PORT=3306

# Local AI search
ALLOW_REMOTE=1
CLIP_MODEL=Xenova/clip-vit-base-patch16
TOP_K=10
AI_SEARCH_WORKER=1

# First-run speed/accuracy tradeoff:
# 60 embeds the strongest visual/color candidates first.
# 0 embeds every missing tile image before ranking.
EMBEDDING_PREFILTER=60
